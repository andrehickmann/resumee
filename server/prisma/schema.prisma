generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  locale      String
  period      String
  start       Int
  end         Int
  title       String
  description String
  tags        String[]
  sortOrder   Int
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published, sortOrder])
  @@map("projects")
}

model Skill {
  id        String   @id @default(uuid()) @db.Uuid
  locale    String
  title     String
  tools     String
  sortOrder Int
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, published, sortOrder])
  @@map("skills")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  locale      String
  title       String
  description String
  sortOrder   Int
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published, sortOrder])
  @@map("services")
}

model Industry {
  id        String   @id @default(uuid()) @db.Uuid
  locale    String
  name      String
  sortOrder Int
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, published, sortOrder])
  @@map("industries")
}

model TimelineEntry {
  id        String   @id @default(uuid()) @db.Uuid
  locale    String
  period    String
  role      String
  summary   String
  sortOrder Int
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, published, sortOrder])
  @@map("timeline_entries")
}
